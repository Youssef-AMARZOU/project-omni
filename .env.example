# ──────────────────────────────────────────────────────────
# OMNI ENTERPRISE - ENVIRONMENT TEMPLATE
# NEVER COMMIT THE REAL .env FILE — USE AWS Secrets Manager
# ou un vault chiffré en production.
# ──────────────────────────────────────────────────────────

# ─── ORCHESTRATOR n8n ───
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_immediately
N8N_HOST=localhost
N8N_PROTOCOL=http

# ─── DATABASES ───
POSTGRES_USER=omni
POSTGRES_PASSWORD=omni_password
POSTGRES_DB=omni_n8n

MONGO_USER=omni
MONGO_PASSWORD=omni_password
MONGO_DB=omni_logs

RABBITMQ_USER=omni
RABBITMQ_PASSWORD=omni_password

# ─── LLM PROVIDERS (Clés API chiffrées en prod) ───
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
HF_API_TOKEN=hf_...

# ─── RAG / VECTOR STORE ───
QDRANT_URL=http://localhost:6333
EMBEDDING_MODEL=text-embedding-3-large
COLLECTION_NAME=omni_tasks

# ─── RESILIENCE ───
FALLBACK_LLM_PROVIDER=anthropic
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60

# ─── LOGGING & MONITORING ───
LOG_LEVEL=INFO
OMNI_DATA_DIR=./data

# ─── JIRA / NOTION / GITHUB / GITLAB ───
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=tech@entreprise.com
JIRA_API_TOKEN=...
JIRA_PROJECT_KEY=OMNI

NOTION_TOKEN=secret_...
NOTION_DATABASE_ID=...

GITHUB_TOKEN=ghp_...
GITHUB_REPO_OWNER=entreprise
GITHUB_REPO_NAME=project-omni

GITLAB_TOKEN=glpat-...
GITLAB_PROJECT_ID=12345678
GITLAB_URL=https://gitlab.com

# ─── Hugging Face Sync ───
HF_REPO_ID=entreprise/project-omni
HF_PRIVATE=false
